---
import type { ImageMetadata } from 'astro';
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import { defaultLang } from '@/i18n/ui';

interface PageProps {
	title: string;
	description: string;
	image?: ImageMetadata;
	translationHref?: string;
}

// Used both as a regular component (props passed directly) and as an MDX/MD
// `layout:` target, where Astro nests all frontmatter under `frontmatter`
// instead of spreading it into Astro.props.
interface Props extends PageProps {
	frontmatter?: PageProps;
}

const { title, description, image, translationHref } = Astro.props.frontmatter ?? Astro.props;
const lang = Astro.currentLocale ?? defaultLang;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<Header translationHref={translationHref} />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
