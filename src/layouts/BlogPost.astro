---
import type { CollectionEntry } from 'astro:content';
import PostArticle from '@/components/PostArticle.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

type Props = CollectionEntry<'posts'>['data'] & {
	// 'profile' puts the hero image beside the title with a blob-shaped crop,
	// for standalone about-me style pages rather than regular posts.
	heroLayout?: 'default' | 'profile';
	// A word/phrase within the profile intro (description) to underline.
	// Only affects the on-page intro, not the <meta description> value.
	introHighlight?: string;
};

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<PostArticle {...Astro.props}>
		<slot />
	</PostArticle>
</BaseLayout>
