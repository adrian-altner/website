---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLang, languages } from '@/i18n/ui';
import { filenameFromPath, formatDate, postUrl, tagUrl, useTranslations } from '@/i18n/utils';

// Standalone pages (e.g. ueber-mich.astro) reuse this layout outside the
// 'posts' collection and don't have a translationId to resolve — they pass
// a translationHref directly instead, which takes precedence when present.
type Props = CollectionEntry<'posts'>['data'] & {
	translationHref?: string;
	// 'profile' puts the hero image beside the title with a blob-shaped crop,
	// for standalone about-me style pages rather than regular posts.
	heroLayout?: 'default' | 'profile';
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	lang: postLang,
	translationId,
	translationHref: translationHrefOverride,
	heroImage,
	heroLayout = 'default',
} = Astro.props;
const lang = Astro.currentLocale ?? postLang ?? defaultLang;
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'de' : 'en';
const translationHref =
	translationHrefOverride ??
	(translationId ? postUrl(otherLang, filenameFromPath(translationId)) : undefined);
// The hint is written in the target language, not the current page's —
// a reader who only speaks that language needs to understand it to switch.
const tOther = useTranslations(otherLang);
---

<BaseLayout title={title} description={description} translationHref={translationHref}>
	<article>
		<header class:list={['post-header', heroLayout === 'profile' && 'post-header--profile']}>
			<div class="post-header-top">
				{heroImage && <Image src={heroImage} width={240} alt={title} class="hero-image" />}
				<div class="post-header-body">
					<h1 class:list={[heroLayout === 'profile' && 'sr-only']}>{title}</h1>
					{heroLayout === 'profile' && (
						<p class="intro">
							{description.split('\n').map((line, i) => (
								<>
									{i > 0 && <br />}
									<span class:list={[i > 0 && 'intro-sub']}>{line}</span>
								</>
							))}
						</p>
					)}
					{heroLayout !== 'profile' && (
						<p class="date">
							<time datetime={pubDate.toISOString()}>{formatDate(pubDate, lang)}</time>
							{updatedDate && (
								<span class="updated">
									{' '}
									· {t('post.updated')}{' '}
									<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate, lang)}</time>
								</span>
							)}
						</p>
					)}
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<a href={tagUrl(lang, tag)} class="tag">#{tag}</a>
							))}
						</div>
					)}
				</div>
			</div>
			<div class="divider">
				<hr />
				{translationHref && (
					<a
						href={translationHref}
						class="translation-hint"
						aria-label={`${tOther('post.alsoAvailable')} ${languages[otherLang]}`}
					>
						{languages[otherLang]} →
					</a>
				)}
			</div>
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.post-header {
		margin-top: 1.5em;
	}
	.post-header h1 {
		font-size: 1.6em;
		margin-bottom: 0.2em;
	}
	.hero-image {
		display: block;
		width: 100%;
		max-width: 240px;
		height: auto;
		margin: 0 0 1em;
		border-radius: 8px;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
	}
	.post-header--profile .post-header-top {
		display: flex;
		align-items: center;
		gap: 1.5em;
		flex-wrap: wrap;
	}
	.post-header--profile .hero-image {
		width: 140px;
		max-width: 140px;
		height: 140px;
		object-fit: cover;
		flex-shrink: 0;
		margin: 0;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		border: 3px solid #fff;
		box-shadow: none;
	}
	.post-header--profile .post-header-body {
		flex: 1;
		min-width: 200px;
	}
	.post-header--profile h1 {
		margin-bottom: 0.2em;
	}
	.intro {
		margin: 0;
		max-width: 22ch;
		font-family: var(--font-heading), system-ui, sans-serif;
		font-size: 1.60em;
		font-weight: 500;
		line-height: 1.35;
		color: var(--text);
	}
	.intro-sub {
		font-weight: 350;
		font-size: 0.85em;
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0;
	}
	.updated {
		font-style: italic;
	}
	.tags {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 0.4em;
	}
	.tag {
		font-size: 0.85em;
		color: var(--muted);
		text-decoration: none;
	}
	.tag:hover {
		color: var(--accent);
	}
	.divider {
		display: flex;
		align-items: center;
		gap: 0.8em;
		margin: 1.5em 0;
	}
	.divider hr {
		flex: 1;
		margin: 0;
	}
	.translation-hint {
		font-size: 0.8em;
		color: var(--muted);
		text-decoration: none;
		white-space: nowrap;
		opacity: 0.7;
	}
	.translation-hint:hover {
		color: var(--accent);
		opacity: 1;
	}
</style>
