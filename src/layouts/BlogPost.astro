---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';
import { defaultLang } from '../i18n/ui';
import { tagUrl, useTranslations } from '../i18n/utils';

type Props = CollectionEntry<'posts'>['data'];

const { title, description, pubDate, updatedDate, tags, lang: postLang } = Astro.props;
const lang = Astro.currentLocale ?? postLang ?? defaultLang;
const t = useTranslations(lang);
---

<BaseLayout title={title} description={description}>
	<article data-pagefind-body>
		<header class="post-header">
			<h1>{title}</h1>
			<p class="date">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<span class="updated"> · {t('post.updated')} <FormattedDate date={updatedDate} /></span>
				)}
			</p>
			{tags && tags.length > 0 && (
				<div class="tags">
					{tags.map((tag) => (
						<a
							href={tagUrl(lang, tag)}
							class="tag"
							data-pagefind-filter="tag[data-tag-value]"
							data-tag-value={tag}
						>#{tag}</a>
					))}
				</div>
			)}
			<hr />
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.post-header {
		margin-top: 1.5em;
	}
	.post-header h1 {
		font-size: 1.6em;
		margin-bottom: 0.2em;
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0;
	}
	.updated {
		font-style: italic;
	}
	.tags {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 0.4em;
	}
	.tag {
		font-size: 0.85em;
		color: var(--muted);
		text-decoration: none;
	}
	.tag:hover {
		color: var(--accent);
	}
</style>
