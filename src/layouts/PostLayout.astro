---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { formatDate } from '@/lib/format';

type Props = CollectionEntry<'posts'>['data'] & {
	// Link target for the title, e.g. when listing posts on the index page.
	href?: string;
	// Show only the first paragraph, with a "Weiterlesen" link to `href`.
	excerpt?: boolean;
};

const { title, pubDate, updatedDate, tags, heroImage, href, excerpt } = Astro.props;
---

<article>
	<header class="post-header">
		<div class="post-header-top">
			{heroImage && <Image src={heroImage} width={240} alt={title} class="hero-image" />}
			<div class="post-header-body">
				<h1>{href ? <a href={href}>{title}</a> : title}</h1>
				<p class="date">
					<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
					{updatedDate && (
						<span class="updated">
							{' '}
							· aktualisiert{' '}
							<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
						</span>
					)}
				</p>
			</div>
		</div>
		<hr class="divider" />
	</header>
	<div class:list={['prose', excerpt && 'prose--excerpt']}>
		<slot />
	</div>
	{excerpt && href && (
		<a href={href} class="read-more">Weiterlesen →</a>
	)}
	{tags && tags.length > 0 && (
		<div class="tags">
			{tags.map((tag) => <span class="tag">#{tag}</span>)}
		</div>
	)}
</article>

<style>
	.post-header {
		margin-top: 0;
	}
	.post-header h1 {
		font-size: 1.6em;
		margin-bottom: 0.2em;
	}
	.post-header h1 a {
		color: inherit;
		text-decoration: none;
	}
	.post-header h1 a:hover {
		text-decoration: underline;
	}
	.hero-image {
		display: block;
		width: 100%;
		max-width: 240px;
		height: auto;
		margin: 0 0 1em;
		border-radius: 8px;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0;
	}
	.updated {
		font-style: italic;
	}
	.tags {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 1.5em;
	}
	.tag {
		font-size: 0.85em;
		color: var(--muted);
	}
	.divider {
		margin: 1.5em 0;
	}
	.prose--excerpt > :global(:not(:first-child)) {
		display: none;
	}
	.read-more {
		display: inline-block;
		margin-top: 1em;
		font-weight: 500;
	}
</style>
