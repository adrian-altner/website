---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'colophon');
if (!entry) throw new Error('Missing content/pages/colophon.md');
const { title, description } = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={title} description={description}>
	<article>
		<header class="page-header">
			<h1>{title}</h1>
			<hr />
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	.page-header h1 {
		font-size: 1.6em;
		margin-bottom: 0.2em;
	}
</style>
