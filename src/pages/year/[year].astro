---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostFilter from '../../components/PostFilter.astro';
import PostList from '../../components/PostList.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('posts');
	const years = [...new Set(allPosts.map((p) => p.data.pubDate.getFullYear()))];
	return years.map((year) => ({
		params: { year: String(year) },
		props: {
			year,
			allPosts,
			posts: allPosts
				.filter((p) => p.data.pubDate.getFullYear() === year)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { year, posts, allPosts } = Astro.props;
const years = [...new Set(allPosts.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={`${year} — ${SITE_TITLE}`} description={`Beiträge aus ${year}`} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{year}</h1>
			<PostFilter {years} {tags} activeYear={year} />
			<PostList {posts} />
		</main>
		<Footer />
	</body>
</html>
