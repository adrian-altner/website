---
import { getCollection } from 'astro:content';
import PostFilter from '../../components/PostFilter.astro';
import PostList from '../../components/PostList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft);
	const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))];
	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			allPosts,
			posts: allPosts
				.filter((p) => p.data.tags?.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts, allPosts } = Astro.props;
const years = [...new Set(allPosts.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
---

<BaseLayout title={`#${tag} — ${SITE_TITLE}`} description={`Alle Beiträge mit Tag #${tag}`}>
	<h1>#{tag}</h1>
	<PostFilter {years} {tags} activeTag={tag} />
	<PostList {posts} />
</BaseLayout>
