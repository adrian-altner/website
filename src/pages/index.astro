---
import PostList from '@/components/PostList.astro';
import Pagination from '@/components/Pagination.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_TITLE, POSTS_PER_PAGE } from '@/consts';
import { getSortedPosts } from '@/lib/posts';

const allPosts = await getSortedPosts();
const posts = allPosts.slice(0, POSTS_PER_PAGE);
const hasNextPage = allPosts.length > POSTS_PER_PAGE;
---

<BaseLayout title={SITE_TITLE} description="Alle Beiträge">
	<h1 class="sr-only">{SITE_TITLE}</h1>
	<PostList posts={posts} />
	<Pagination nextUrl={hasNextPage ? '/seite/2' : undefined} />
</BaseLayout>
