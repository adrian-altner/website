---
import { getCollection } from 'astro:content';
import PostList from '@/components/PostList.astro';
import PostFilters from '@/components/PostFilters.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_TITLE } from '@/consts';
import { defaultLang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';

const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);

const posts = (
	await getCollection(
		'posts',
		({ data }) => (import.meta.env.DEV || !data.draft) && data.lang === lang,
	)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={SITE_TITLE} description={t('index.description')}>
	<h1 class="sr-only">{SITE_TITLE}</h1>
	<PostFilters />
	<div data-post-index>
		{posts.length === 0 ? <p>{t('index.empty')}</p> : <PostList {posts} />}
	</div>
</BaseLayout>

<style>
	div {
		margin-top: 1.5em;
	}
</style>
