---
import { defaultLang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);
const colophonHref = lang === 'en' ? '/en/colophon' : '/kolophon';
const rssHref = lang === 'en' ? '/en/rss.xml' : '/rss.xml';
const imprintHref = lang === 'en' ? '/en/imprint' : '/impressum';
const privacyHref = lang === 'en' ? '/en/privacy-policy' : '/datenschutz';
---

<footer>
	<div class="footer-inner">
		<a href={rssHref} aria-label={t('footer.subscribe')}>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M4 11a9 9 0 0 1 9 9"></path>
				<path d="M4 4a16 16 0 0 1 16 16"></path>
				<circle cx="5" cy="19" r="1"></circle>
			</svg>
		</a>
		<a href={colophonHref} aria-label={t('footer.colophon')}>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="10"></circle>
				<line x1="12" y1="16" x2="12" y2="12"></line>
				<line x1="12" y1="8" x2="12.01" y2="8"></line>
			</svg>
		</a>
		<a href={imprintHref} aria-label={t('footer.imprint')}>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
				<path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
				<path d="M10 9H8"></path>
				<path d="M16 13H8"></path>
				<path d="M16 17H8"></path>
			</svg>
		</a>
		<a href={privacyHref} aria-label={t('footer.privacy')}>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M20 13c0 5-3.5 7.5-7.5 8.5-.4.1-.6.1-1 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
			</svg>
		</a>
	</div>
</footer>

<style>
	footer {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 0 1em 2em;
	}
	.footer-inner {
		display: flex;
		gap: 1em;
		align-items: center;
		justify-content: flex-end;
	}
	.footer-inner a {
		position: relative;
		display: inline-flex;
		color: var(--muted);
	}
	.footer-inner a:hover {
		color: var(--accent);
	}
	.footer-inner svg {
		width: 1.3em;
		height: 1.3em;
	}
	.footer-inner a::after {
		content: attr(aria-label);
		position: absolute;
		bottom: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(-0.4em);
		background: var(--text);
		color: var(--bg);
		font-family: var(--font-mono), ui-monospace, monospace;
		font-size: 0.75rem;
		white-space: nowrap;
		padding: 0.3em 0.6em;
		border-radius: 4px;
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.15s ease,
			transform 0.15s ease;
	}
	.footer-inner a:hover::after {
		opacity: 1;
		transform: translateX(-50%) translateY(-0.6em);
	}
</style>
