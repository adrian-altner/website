---
import { Search } from '@lucide/astro';
import SearchDialog from './SearchDialog.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<a class="site-title" href="/">{SITE_TITLE}</a>
	<nav>
		<a href="/">Start</a>
		<a href="/blog">Blog</a>
		<a href="/about">Über mich</a>
		<button type="button" id="search-trigger" aria-label="Suche öffnen">
			<Search size={18} strokeWidth={2} />
		</button>
	</nav>
</header>

<SearchDialog />

<script>
	const links = document.querySelectorAll('header nav a');
	links.forEach((link) => {
		const href = link.getAttribute('href');
		const path = window.location.pathname;
		if (href === path || (href !== '/' && path.startsWith(href))) {
			link.classList.add('active');
		}
	});
</script>

<style>
	header {
		width: 600px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2em 1em 0;
	}
	.site-title {
		display: block;
		font-size: 1.4em;
		font-weight: bold;
		text-decoration: none;
		color: var(--text);
		margin-bottom: 0.2em;
	}
	.site-title:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
		margin-bottom: 0;
	}
	nav a {
		color: var(--accent);
		text-decoration: underline;
		font-size: 0.95em;
	}
	nav a:hover,
	nav a.active {
		color: var(--accent-hover);
		font-weight: bold;
	}
	#search-trigger {
		display: inline-flex;
		align-items: center;
		background: none;
		border: none;
		padding: 0;
		margin: 0;
		color: var(--accent);
		cursor: pointer;
	}
	#search-trigger:hover {
		color: var(--accent-hover);
	}
	hr {
		margin-top: 1.2em;
	}
</style>
