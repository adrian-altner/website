---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { SITE_TITLE } from '../consts';
import { defaultLang, languages } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);
---

<header>
	<div class="header-top">
		<a class="site-title" href={getRelativeLocaleUrl(lang, '/')}>{SITE_TITLE}</a>
		<nav>
			<a href={getRelativeLocaleUrl(lang, '/')} data-home>{t('nav.posts')}</a>
			<a href="/ueber-mich">{t('nav.about')}</a>
			<span class="lang-switch">
				{Object.keys(languages).map((code) =>
					code === lang ? (
						<span class="lang-current" aria-current="true">{code.toUpperCase()}</span>
					) : (
						<a href={getRelativeLocaleUrl(code, '/')}>{code.toUpperCase()}</a>
					),
				)}
			</span>
		</nav>
	</div>
</header>

<script>
	const links = document.querySelectorAll('header nav > a');
	links.forEach((link) => {
		const href = link.getAttribute('href');
		if (!href) return;
		const path = window.location.pathname;
		const isHome = link.hasAttribute('data-home');
		if (href === path || (!isHome && path.startsWith(href))) {
			link.classList.add('active');
			link.setAttribute('aria-current', 'page');
		}
	});
</script>

<style>
	header {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2em 1em 0;
	}
	.header-top {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.3em 1em;
	}
	.site-title {
		font-size: 1.4em;
		font-weight: bold;
		text-decoration: none;
		color: var(--text);
	}
	.site-title:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}
	nav a {
		display: inline-block;
		padding: 0.3em 0;
		color: var(--accent);
		text-decoration: underline;
		font-size: 0.95em;
	}
	nav a:hover {
		color: var(--accent-hover);
	}
	nav a.active {
		color: var(--accent-hover);
		font-weight: bold;
	}
	.lang-switch {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding-left: 0.6em;
		border-left: 1px solid var(--border);
		font-size: 0.85em;
	}
	.lang-switch a {
		text-decoration: none;
		color: var(--muted);
	}
	.lang-switch a:hover {
		color: var(--accent);
	}
	.lang-current {
		font-weight: bold;
		color: var(--text);
	}
</style>
