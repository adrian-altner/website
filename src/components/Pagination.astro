---
interface Props {
	prevUrl?: string;
	nextUrl?: string;
}

const { prevUrl, nextUrl } = Astro.props;
---

{
	(prevUrl || nextUrl) && (
		<nav class="pagination" aria-label="Seitennavigation">
			{prevUrl ? <a href={prevUrl}>← Neuere Beiträge</a> : <span />}
			{nextUrl && <a href={nextUrl}>Ältere Beiträge →</a>}
		</nav>
	)
}

<style>
	.pagination {
		display: flex;
		justify-content: space-between;
		gap: 1em;
		margin-top: 3em;
	}
</style>
