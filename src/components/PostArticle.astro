---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { formatDate } from '@/lib/format';

type Props = CollectionEntry<'posts'>['data'] & {
	// 'profile' puts the hero image beside the title with a blob-shaped crop,
	// for standalone about-me style pages rather than regular posts.
	heroLayout?: 'default' | 'profile';
	// A word/phrase within the profile intro (description) to underline.
	// Only affects the on-page intro, not the <meta description> value.
	introHighlight?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	heroImage,
	heroLayout = 'default',
	introHighlight,
} = Astro.props;
---

<article>
	<header class:list={['post-header', heroLayout === 'profile' && 'post-header--profile']}>
		<div class="post-header-top">
			{heroImage && <Image src={heroImage} width={240} alt={title} class="hero-image" />}
			<div class="post-header-body">
				<h1 class:list={[heroLayout === 'profile' && 'sr-only']}>{title}</h1>
				{heroLayout === 'profile' && (
					<p class="intro">
						{description.split('\n').map((line, i) => {
							const idx = introHighlight ? line.indexOf(introHighlight) : -1;
							return (
								<>
									{i > 0 && <br />}
									<span class:list={[i > 0 && 'intro-sub']}>
										{idx === -1 ? (
											line
										) : (
											<>
												{line.slice(0, idx)}
												<u>{introHighlight}</u>
												{line.slice(idx + introHighlight!.length)}
											</>
										)}
									</span>
								</>
							);
						})}
					</p>
				)}
				{heroLayout !== 'profile' && (
					<p class="date">
						<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
						{updatedDate && (
							<span class="updated">
								{' '}
								· aktualisiert{' '}
								<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
							</span>
						)}
					</p>
				)}
			</div>
		</div>
		<hr class="divider" />
	</header>
	<div class="prose">
		<slot />
	</div>
	{tags && tags.length > 0 && (
		<div class="tags">
			{tags.map((tag) => <span class="tag">#{tag}</span>)}
		</div>
	)}
</article>

<style>
	.post-header {
		margin-top: 1.5em;
	}
	.post-header h1 {
		font-size: 1.6em;
		margin-bottom: 0.2em;
	}
	.hero-image {
		display: block;
		width: 100%;
		max-width: 240px;
		height: auto;
		margin: 0 0 1em;
		border-radius: 8px;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
	}
	.post-header--profile .post-header-top {
		display: flex;
		align-items: center;
		gap: 1.5em;
		flex-wrap: wrap;
	}
	.post-header--profile .hero-image {
		width: 140px;
		max-width: 140px;
		height: 140px;
		object-fit: cover;
		flex-shrink: 0;
		margin: 0;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		border: 3px solid #fff;
		box-shadow: none;
	}
	.post-header--profile .post-header-body {
		flex: 1;
		min-width: 200px;
	}
	.post-header--profile h1 {
		margin-bottom: 0.2em;
	}
	.intro {
		margin: 0;
		max-width: 22ch;
		font-family: var(--font-heading), system-ui, sans-serif;
		font-size: 1.60em;
		font-weight: 500;
		line-height: 1.35;
		color: var(--text);
	}
	.intro-sub {
		font-weight: 350;
		font-size: 0.85em;
	}
	.intro u {
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-underline-offset: 0.15em;
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0;
	}
	.updated {
		font-style: italic;
	}
	.tags {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 1.5em;
	}
	.tag {
		font-size: 0.85em;
		color: var(--muted);
	}
	.divider {
		margin: 1.5em 0;
	}
</style>
