---
import { getCollection } from 'astro:content';
import { defaultLang } from '../i18n/ui';
import { postUrl, tagUrl, useTranslations } from '../i18n/utils';

// Strips just enough Markdown syntax that a fuzzy-matched excerpt from the raw
// body reads as plain text instead of showing stray #, *, [] characters.
function stripMarkdown(md: string) {
	return md
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[.*?\]\(.*?\)/g, ' ')
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
		.replace(/[#>*_`~]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();
}

// Matches FormattedDate's `iso` mode so tag-only browsing (rendered from this
// index, see below) shows the same date format as the normal post list.
function formatIsoDate(date: Date) {
	return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
}

const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);
const messages = {
	searching: t('search.searching'),
	noResults: t('search.noResults'),
	resultOne: t('search.resultOne'),
	resultsTemplate: t('search.resultsTemplate'),
	devOnly: t('search.devOnly'),
};

// Title/description/tag/body index for the client-side fuzzy fallback (see below) —
// Pagefind itself does no typo-tolerant matching, only stemming and prefix matching.
const posts = await getCollection(
	'posts',
	({ data }) => (import.meta.env.DEV || !data.draft) && data.lang === lang,
);
const searchIndex = posts.map((post) => ({
	title: post.data.title,
	url: postUrl(post.data.lang, post.id),
	description: post.data.description,
	tags: post.data.tags ?? [],
	tagLinks: (post.data.tags ?? []).map((tag) => ({ tag, url: tagUrl(post.data.lang, tag) })),
	pubDate: post.data.pubDate.valueOf(),
	pubDateDisplay: formatIsoDate(post.data.pubDate),
	body: stripMarkdown(post.body ?? ''),
}));
---

<div id="search-backdrop" hidden></div>
<div class="search">
	<label for="search-input" class="sr-only">{t('search.label')}</label>
	<input id="search-input" type="search" placeholder={t('search.placeholder')} autocomplete="off" />
	<button type="button" id="search-clear" aria-label={t('search.close')} hidden>×</button>
	<div id="active-tag-bar" hidden>
		<button type="button" id="active-tag-chip"></button>
	</div>
	<div id="search-panel" hidden>
		<div id="search-filters" hidden></div>
		<p id="search-status" aria-live="polite"></p>
		<ul id="search-results"></ul>
		<div id="search-suggestions" hidden>
			<p class="suggestions-label">{t('search.suggestions')}</p>
			<ul id="search-suggestions-list"></ul>
		</div>
	</div>
</div>
<script type="application/json" id="search-index-data" is:inline set:html={JSON.stringify(searchIndex)} />
<script type="application/json" id="search-messages-data" is:inline set:html={JSON.stringify(messages)} />

<script>
	const container = document.querySelector('.search');
	const input = document.getElementById('search-input');
	const clearBtn = document.getElementById('search-clear');
	const panel = document.getElementById('search-panel');
	const backdrop = document.getElementById('search-backdrop');
	const filtersEl = document.getElementById('search-filters');
	const activeTagBar = document.getElementById('active-tag-bar');
	const activeTagChip = document.getElementById('active-tag-chip');
	const statusEl = document.getElementById('search-status');
	const resultsEl = document.getElementById('search-results');
	const suggestionsEl = document.getElementById('search-suggestions');
	const suggestionsListEl = document.getElementById('search-suggestions-list');
	const indexDataEl = document.getElementById('search-index-data');
	const messagesDataEl = document.getElementById('search-messages-data');
	const messages = JSON.parse(messagesDataEl?.textContent || '{}');
	const searchIndex = JSON.parse(indexDataEl?.textContent || '[]');

	if (
		container &&
		input &&
		clearBtn &&
		panel &&
		backdrop &&
		filtersEl &&
		activeTagBar &&
		activeTagChip &&
		statusEl &&
		resultsEl &&
		suggestionsEl &&
		suggestionsListEl
	) {
		let pagefind;
		let pagefindPromise = null;
		let allTagCounts = {};
		let currentQuery = '';
		let activeTag = null;
		let requestToken = 0;
		let debounceTimer;
		let fusePromise = null;

		function loadPagefind() {
			if (!pagefindPromise) {
				// Runs only after `npm run build` generates this into dist/client/pagefind/ — indirect
				// `Function` call keeps Vite's bundler from statically analyzing/rewriting the import,
				// which otherwise breaks with a ReferenceError on the unresolved `__VITE_PRELOAD__` token.
				const importPagefind = new Function('url', 'return import(url)');
				pagefindPromise = importPagefind('/pagefind/pagefind.js')
					.then(async (mod) => {
						pagefind = mod;
						// Also used to pre-populate the tag chips on focus, before any query is typed.
						const filters = await mod.filters().catch(() => ({}));
						allTagCounts = filters.tag ?? {};
					})
					.catch(() => {
						statusEl.textContent = messages.devOnly;
					});
			}
			return pagefindPromise;
		}

		// Only loaded on the rare zero-result path, so it never adds weight to the
		// normal search flow — Pagefind alone handles everything else.
		function loadFuse() {
			if (!fusePromise) {
				fusePromise = import('fuse.js').then(({ default: Fuse }) => {
					return new Fuse(searchIndex, {
						keys: [
							{ name: 'title', weight: 3 },
							{ name: 'description', weight: 2 },
							{ name: 'tags', weight: 2 },
							{ name: 'body', weight: 1 },
						],
						threshold: 0.3,
						minMatchCharLength: 3,
						ignoreLocation: true,
						includeMatches: true,
					});
				});
			}
			return fusePromise;
		}

		function escapeHtml(str) {
			return str.replace(
				/[&<>"']/g,
				(c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c],
			);
		}

		// Builds a Pagefind-style excerpt: a window of plain text around the matched
		// range with the match itself wrapped in <mark>, rather than the raw field value.
		function highlightSnippet(text, indices, padding = 40) {
			if (!indices || indices.length === 0) return null;
			const [start, end] = indices[0];
			const from = Math.max(0, start - padding);
			const to = Math.min(text.length, end + 1 + padding);
			const prefix = from > 0 ? '…' : '';
			const suffix = to < text.length ? '…' : '';
			const before = escapeHtml(text.slice(from, start));
			const match = escapeHtml(text.slice(start, end + 1));
			const after = escapeHtml(text.slice(end + 1, to));
			return `${prefix}${before}<mark>${match}</mark>${after}${suffix}`;
		}

		// Prefers a body match (most context) over a description match; a title/tag-only
		// match gets no excerpt since there's nothing more to show beyond the title itself.
		function buildExcerpt(item, fieldMatches) {
			const bodyMatch = fieldMatches?.find((m) => m.key === 'body');
			if (bodyMatch) return highlightSnippet(item.body, bodyMatch.indices);
			const descMatch = fieldMatches?.find((m) => m.key === 'description');
			if (descMatch) return highlightSnippet(item.description, descMatch.indices);
			return null;
		}

		function setBackgroundInert(isInert) {
			document.querySelectorAll('.site-title, header nav, main, footer').forEach((el) => {
				if (isInert) el.setAttribute('inert', '');
				else el.removeAttribute('inert');
			});
		}

		function showPanel() {
			panel.hidden = false;
			// Doubles as the close button while the panel is open — saves the extra
			// row a separate "Schließen" button would need.
			clearBtn.hidden = false;
			updateActiveTagIndicator();
		}

		// Closing the search box ends the session entirely, rather than leaving the
		// tag filter silently active in the background — otherwise the page looks
		// like a plain, unfiltered view while a filter is still armed for next time,
		// with nothing on screen (query text, results, page content) explaining why.
		function hidePanel() {
			panel.hidden = true;
			hideDim();
			input.value = '';
			clearBtn.hidden = true;
			currentQuery = '';
			activeTag = null;
			resultsEl.innerHTML = '';
			statusEl.textContent = '';
			filtersEl.innerHTML = '';
			filtersEl.hidden = true;
			clearSuggestions();
			updateActiveTagIndicator();
			updateUrl();
		}

		// Dimming (and trapping focus to the search widget) is reserved for once
		// there's actually something active to search — a bare focus only previews
		// the tag chips and shouldn't darken the whole page or block tabbing away.
		function showDim() {
			backdrop.hidden = false;
			setBackgroundInert(true);
		}

		function hideDim() {
			backdrop.hidden = true;
			setBackgroundInert(false);
		}

		// Shows the tag indicator only while the panel is closed — with the panel
		// open, the same tag is already shown as the active chip in the filter
		// list, so showing both at once is just duplicate UI.
		function updateActiveTagIndicator() {
			if (activeTag && panel.hidden) {
				activeTagBar.hidden = false;
				activeTagChip.textContent = `#${activeTag} ×`;
			} else {
				activeTagBar.hidden = true;
			}
		}

		function renderChips(tagCounts) {
			filtersEl.innerHTML = '';
			// Sorted alphabetically rather than left in Pagefind's count-derived order,
			// so a chip doesn't jump position while the user is still typing.
			const entries = Object.entries(tagCounts).sort((a, b) => a[0].localeCompare(b[0]));
			if (entries.length === 0) {
				filtersEl.hidden = true;
				return;
			}
			filtersEl.hidden = false;
			for (const [value, count] of entries) {
				const chip = document.createElement('button');
				chip.type = 'button';
				chip.className = 'chip';
				const isActive = value === activeTag;
				if (isActive) chip.classList.add('active');
				chip.setAttribute('aria-pressed', String(isActive));
				chip.textContent = `#${value} (${count})`;
				chip.addEventListener('click', () => {
					activeTag = activeTag === value ? null : value;
					updateActiveTagIndicator();
					runSearch();
				});
				filtersEl.appendChild(chip);
			}
		}

		function renderResults(results, total) {
			resultsEl.innerHTML = '';
			if (results.length === 0) {
				statusEl.textContent = messages.noResults;
				return;
			}
			statusEl.textContent =
				total === 1 ? messages.resultOne : messages.resultsTemplate.replace('{n}', String(total));
			for (const result of results) {
				const li = document.createElement('li');
				const a = document.createElement('a');
				a.href = result.url;
				a.textContent = result.meta?.title ?? result.url;
				const p = document.createElement('p');
				p.className = 'excerpt';
				p.innerHTML = result.excerpt;
				li.append(a, p);
				resultsEl.appendChild(li);
			}
		}

		// Pure tag browsing (no text typed) has no match to excerpt or highlight, so
		// it renders like the normal post list — title, description, tag links, date —
		// instead of Pagefind's search-excerpt style used for actual text queries.
		function renderPostListResults(posts) {
			resultsEl.innerHTML = '';
			if (posts.length === 0) {
				statusEl.textContent = messages.noResults;
				return;
			}
			statusEl.textContent =
				posts.length === 1 ? messages.resultOne : messages.resultsTemplate.replace('{n}', String(posts.length));
			for (const post of posts) {
				const li = document.createElement('li');
				const meta = document.createElement('div');
				meta.className = 'post-meta';
				const a = document.createElement('a');
				a.className = 'post-title';
				a.href = post.url;
				a.textContent = post.title;
				const desc = document.createElement('p');
				desc.className = 'post-desc';
				desc.textContent = post.description;
				meta.append(a, desc);
				if (post.tagLinks.length > 0) {
					const tagsDiv = document.createElement('div');
					tagsDiv.className = 'tags';
					for (const { tag, url } of post.tagLinks) {
						const tagA = document.createElement('a');
						tagA.className = 'tag';
						tagA.href = url;
						tagA.textContent = `#${tag}`;
						tagsDiv.appendChild(tagA);
					}
					meta.appendChild(tagsDiv);
				}
				const date = document.createElement('span');
				date.className = 'date';
				date.textContent = post.pubDateDisplay;
				li.append(meta, date);
				resultsEl.appendChild(li);
			}
		}

		function clearSuggestions() {
			suggestionsListEl.innerHTML = '';
			suggestionsEl.hidden = true;
		}

		// Runs alongside real results too, not just when there are none — Pagefind's
		// prefix matching often already finds something for a typo, but the fuzzy
		// index (title/description/tags) can still surface a closer match it missed.
		async function renderSuggestions(query, shownUrls) {
			const fuse = await loadFuse();
			const matches = fuse
				.search(query)
				.filter(({ item }) => !shownUrls.includes(item.url))
				.slice(0, 5);
			if (matches.length === 0) {
				clearSuggestions();
				return;
			}
			suggestionsListEl.innerHTML = '';
			suggestionsEl.hidden = false;
			for (const { item, matches: fieldMatches } of matches) {
				const li = document.createElement('li');
				const a = document.createElement('a');
				a.href = item.url;
				a.textContent = item.title;
				li.appendChild(a);
				const excerptHtml = buildExcerpt(item, fieldMatches);
				if (excerptHtml) {
					const p = document.createElement('p');
					p.className = 'excerpt';
					p.innerHTML = excerptHtml;
					li.appendChild(p);
				}
				suggestionsListEl.appendChild(li);
			}
		}

		// Mirrors query + tag into the URL via replaceState (never pushState) so a
		// reload or shared link restores the same search, without spamming history
		// on every keystroke.
		function updateUrl() {
			const params = new URLSearchParams();
			if (currentQuery) params.set('q', currentQuery);
			if (activeTag) params.set('tag', activeTag);
			const qs = params.toString();
			const newUrl = location.pathname + (qs ? `?${qs}` : '') + location.hash;
			history.replaceState(null, '', newUrl);
		}

		async function runSearch() {
			updateUrl();
			// Bumps the token even on branches below that never await anything, so a
			// still-in-flight Pagefind request from a previous query can't resolve
			// later and clobber what these synchronous branches just rendered.
			requestToken++;
			if (!currentQuery && !activeTag) {
				// pagefind is already loaded by this point — a chip can only exist (and be
				// clickable) once loadPagefind() has resolved and populated allTagCounts —
				// so this path stays fully synchronous, with no await-induced timing gap.
				resultsEl.innerHTML = '';
				statusEl.textContent = '';
				clearSuggestions();
				renderChips(allTagCounts);
				showPanel();
				hideDim();
				return;
			}
			if (!currentQuery && activeTag) {
				// No text to match/highlight, so skip Pagefind entirely and render like
				// the normal post list instead of a search-excerpt list.
				const matches = searchIndex
					.filter((post) => post.tags.includes(activeTag))
					.sort((a, b) => b.pubDate - a.pubDate);
				const tagCounts = {};
				for (const post of matches) {
					for (const tag of post.tags) tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
				}
				clearSuggestions();
				renderChips(tagCounts);
				renderPostListResults(matches);
				showPanel();
				showDim();
				return;
			}
			await loadPagefind();
			if (!pagefind) return;
			showPanel();
			showDim();
			clearSuggestions();
			const token = ++requestToken;
			statusEl.textContent = messages.searching;
			const search = await pagefind.search(
				currentQuery || null,
				activeTag ? { filters: { tag: activeTag } } : undefined,
			);
			if (token !== requestToken) return;
			const results = await Promise.all(search.results.slice(0, 20).map((r) => r.data()));
			if (token !== requestToken) return;
			// No tag chips during a text search — with 10-20+ tags on the site, the
			// chip row would compete with the input for space; only the matching
			// post(s) are shown here.
			filtersEl.innerHTML = '';
			filtersEl.hidden = true;
			renderResults(results, search.results.length);
			if (currentQuery) {
				renderSuggestions(
					currentQuery,
					results.map((r) => r.url),
				);
			} else {
				clearSuggestions();
			}
		}

		input.addEventListener('focus', async () => {
			if (!currentQuery && !activeTag) {
				// Open right away so focus gets instant feedback — the chips themselves
				// still depend on pagefind's index and pop in once that resolves.
				showPanel();
				await loadPagefind();
				if (!currentQuery && !activeTag) renderChips(allTagCounts);
			} else {
				showPanel();
				showDim();
			}
		});

		// Capture phase: runs top-down, before the click reaches its target — so it
		// evaluates containment before a chip's own click handler can synchronously
		// replace itself (e.g. via renderChips), which would otherwise detach the
		// event target from the DOM first and make this check false-positive.
		document.addEventListener(
			'click',
			(event) => {
				if (!container.contains(event.target)) hidePanel();
			},
			true,
		);

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !panel.hidden) {
				hidePanel();
				input.blur();
			}
		});

		input.addEventListener('input', () => {
			clearTimeout(debounceTimer);
			currentQuery = input.value.trim();
			// Typing text drops any active tag filter — combining "search within this
			// tag" with free text was confusing, so the two are mutually exclusive:
			// text search always searches the whole site.
			if (currentQuery && activeTag) {
				activeTag = null;
				updateActiveTagIndicator();
			}
			debounceTimer = setTimeout(runSearch, 180);
		});

		// Doubles as the panel's close button (see showPanel) — Escape and
		// click-outside both work too, but neither is obvious on mobile without a
		// keyboard, so this stays the explicit, always-visible affordance.
		clearBtn.addEventListener('click', () => {
			hidePanel();
			input.blur();
		});

		activeTagChip.addEventListener('click', () => {
			activeTag = null;
			updateActiveTagIndicator();
			runSearch();
		});

		// Restore query/tag from the URL (e.g. a shared link or a reload) so the
		// same search reappears instead of a blank, unfocused input.
		const initialParams = new URLSearchParams(location.search);
		const initialQuery = initialParams.get('q') ?? '';
		const initialTag = initialParams.get('tag');
		if (initialQuery || initialTag) {
			input.value = initialQuery;
			currentQuery = initialQuery.trim();
			activeTag = initialTag;
			updateActiveTagIndicator();
			runSearch();
		}

		// Warm the pagefind index up during idle time so it's already loaded by
		// the time someone actually focuses the search box.
		if ('requestIdleCallback' in window) {
			requestIdleCallback(() => loadPagefind());
		} else {
			setTimeout(() => loadPagefind(), 200);
		}
	}
</script>

<style>
	#search-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 9;
	}
	.search {
		position: relative;
		z-index: 10;
		margin-top: 1em;
	}
	#search-input {
		width: 100%;
		padding: 0.5em 2.6em 0.5em 0.7em;
		border: 1px solid var(--border);
		border-radius: 4px;
		background: var(--bg);
		color: var(--text);
		font: inherit;
		font-size: 1em;
	}
	#search-input:focus {
		outline: none;
		border-bottom-color: var(--accent);
	}
	#search-input::-webkit-search-cancel-button {
		display: none;
	}
	#search-clear {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		align-items: center;
		justify-content: center;
		width: 2.4em;
		padding: 0;
		border: none;
		border-radius: 0 4px 0 0;
		background: var(--accent);
		color: var(--bg);
		font-size: 1.3em;
		line-height: 1;
		cursor: pointer;
	}
	#search-clear:not([hidden]) {
		display: flex;
	}
	#search-clear:hover {
		filter: brightness(1.1);
	}
	.search:has(#search-panel:not([hidden])) #search-input {
		border-radius: 4px 4px 0 0;
	}
	#active-tag-bar {
		margin-top: 0.5em;
	}
	#active-tag-chip {
		font: inherit;
		font-size: 0.85em;
		color: var(--bg);
		background: var(--accent);
		border: 1px solid var(--accent);
		border-radius: 999px;
		padding: 0.2em 0.7em;
		font-weight: bold;
		cursor: pointer;
	}
	#search-panel {
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		padding: 0.8em;
		border: 1px solid var(--border);
		border-top: none;
		border-radius: 0 0 4px 4px;
		background: var(--bg);
		z-index: 10;
	}
	#search-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}
	#search-filters :global(.chip) {
		font: inherit;
		font-size: 0.85em;
		color: var(--muted);
		background: none;
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.2em 0.7em;
		cursor: pointer;
	}
	#search-filters :global(.chip:hover) {
		color: var(--accent);
	}
	#search-filters :global(.chip.active) {
		color: var(--bg);
		background: var(--accent);
		border-color: var(--accent);
		font-weight: bold;
	}
	#search-status {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0.8em 0 0;
	}
	#search-status:first-child {
		margin-top: 0;
	}
	#search-results {
		list-style: none;
		padding: 0;
		margin: 0.8em 0 0;
		max-height: 50vh;
		overflow-y: auto;
	}
	#search-results:first-child {
		margin-top: 0;
	}
	#search-results :global(li) {
		padding: 0.6em 0;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1.5em;
		flex-wrap: wrap;
	}
	#search-results :global(li:first-child) {
		border-top: none;
	}
	#search-results :global(a) {
		font-weight: bold;
	}
	#search-results :global(.excerpt) {
		color: var(--muted);
		font-size: 0.9em;
		margin: 0.2em 0 0;
	}
	#search-results :global(mark) {
		background: var(--accent);
		color: var(--bg);
		border-radius: 2px;
	}
	/* Pure tag browsing renders like PostList.astro's list — mirrors its
	   classes/layout here since dynamically created nodes can't reuse its
	   scoped styles directly. */
	#search-results :global(.post-meta) {
		flex: 1;
	}
	#search-results :global(.post-desc) {
		color: var(--muted);
		font-size: 0.9em;
		font-weight: normal;
		margin: 0.1em 0 0;
	}
	#search-results :global(.tags) {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
