---
interface Props {
	date: Date;
	iso?: boolean;
}

const { date, iso = false } = Astro.props;
const formatted = iso
	? `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`
	: date.toLocaleDateString('de-DE', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		});
---

<time datetime={date.toISOString()}>{formatted}</time>
