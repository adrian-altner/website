---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { postUrl } from '../i18n/utils';

interface Props {
	posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

<ul>
	{posts.map((post) => (
		<li data-tags={(post.data.tags ?? []).join(',')} data-year={post.data.pubDate.getFullYear()}>
			<span class="date"><FormattedDate date={post.data.pubDate} iso /></span>
			<div class="post-meta">
				<a href={postUrl(post.data.lang, post.id)} class="post-title">{post.data.title}</a>
			</div>
		</li>
	))}
</ul>

<style>
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	li {
		display: flex;
		align-items: baseline;
		gap: 1em;
		padding: 0.5em 0;
	}
	li[hidden] {
		display: none;
	}
	.post-meta {
		flex: 1;
		min-width: 0;
	}
	.post-title {
		font-weight: bold;
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
		flex-shrink: 0;
	}
</style>
