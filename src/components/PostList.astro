---
import type { CollectionEntry } from 'astro:content';
import { formatDate, postUrl } from '@/lib/format';

interface Props {
	posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

<ul>
	{posts.map((post) => (
		<li>
			<span class="date">
				<time datetime={post.data.pubDate.toISOString()}>
					{formatDate(post.data.pubDate, { iso: true })}
				</time>
			</span>
			<div class="post-meta">
				<a href={postUrl(post.id)} class="post-title">{post.data.title}</a>
			</div>
		</li>
	))}
</ul>

<style>
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	li {
		display: flex;
		align-items: baseline;
		gap: 1em;
		padding: 0.5em 0;
	}
	.post-meta {
		flex: 1;
		min-width: 0;
	}
	.post-title {
		font-weight: bold;
		font-family: var(--font-heading), system-ui, sans-serif;
	}
	.date {
		color: var(--muted);
		font-size: 0.9em;
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
		flex-shrink: 0;
	}
</style>
