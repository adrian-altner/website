---
import { getCollection } from 'astro:content';
import { defaultLang } from '../i18n/ui';
import { tagUrl, useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);

const posts = await getCollection(
	'posts',
	({ data }) => (import.meta.env.DEV || !data.draft) && data.lang === lang,
);

const tagCounts = new Map<string, number>();
const yearCounts = new Map<number, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
	const year = post.data.pubDate.getFullYear();
	yearCounts.set(year, (yearCounts.get(year) ?? 0) + 1);
}
// Most-used first — with the "more tags" collapse below, this keeps the
// always-visible slice the most relevant one instead of an arbitrary
// alphabetical prefix.
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const years = [...yearCounts.entries()].sort((a, b) => b[0] - a[0]);
---

{
	(years.length > 0 || tags.length > 0) && (
		<div class="post-filters">
			{years.length > 0 && (
				<ul class="filter-menu">
					{years.map(([year, count]) => (
						<li>
							{/* Years have no dedicated static page (unlike tags), so this is a
							   plain button — a pure JS filter control, nothing to link to. */}
							<button type="button" data-year={year}>
								{year} <span class="count">({count})</span>
							</button>
						</li>
					))}
				</ul>
			)}
			{tags.length > 0 && (
				<ul class="filter-menu tags-menu">
					{tags.map(([tag, count]) => (
						<li>
							{/* href keeps this a real, shareable link even without JS (just
							   unfiltered) — the script below intercepts the click to filter
							   in place instead of reloading */}
							<a href={tagUrl(lang, tag)} data-tag={tag}>
								#{tag} <span class="count">({count})</span>
							</a>
						</li>
					))}
				</ul>
			)}
			{/* Only shown by the script below once there are more tags than fit
			   the collapsed view. */}
			<button type="button" class="toggle-tags" hidden>
				<span class="label-more">{t('filters.showMoreTags')} ▾</span>
				<span class="label-less">{t('filters.showFewerTags')} ▴</span>
			</button>
			{/* Only ever shown by the script below, once a live filter is actually active. */}
			<div class="filter-status" hidden>
				<p class="status-line">
					<span class="status-label">{t('filters.filteringFor')}</span>
					<button type="button" class="chip" data-remove="year" hidden />
					<span class="tag-chips" />
				</p>
				<button type="button" class="reset">{t('filters.reset')}</button>
			</div>
		</div>
	)
}

<style>
	.post-filters {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		margin-top: 1em;
	}
	.filter-menu {
		display: flex;
		flex-wrap: wrap;
		gap: 0 0.8em;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.tags-menu {
		overflow: hidden;
		transition: max-height 0.2s ease;
	}
	a,
	.filter-menu button {
		font: inherit;
		color: var(--muted);
		background: none;
		border: none;
		padding: 0;
		font-size: 0.85em;
		text-decoration: none;
		cursor: pointer;
	}
	a:hover,
	.filter-menu button:hover {
		color: var(--accent);
	}
	a.active,
	.filter-menu button.active {
		color: var(--accent);
		font-weight: bold;
		text-decoration: underline;
	}
	.count {
		color: var(--muted);
	}
	.toggle-tags {
		display: block;
		text-align: left;
		margin-top: -0.2em;
		font: inherit;
		font-size: 0.85em;
		color: var(--muted);
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
	}
	.toggle-tags[hidden] {
		display: none;
	}
	.toggle-tags:hover {
		color: var(--accent);
	}
	.toggle-tags .label-less {
		display: none;
	}
	.toggle-tags.expanded .label-more {
		display: none;
	}
	.toggle-tags.expanded .label-less {
		display: inline;
	}
	.filter-status {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 0.7em 1em;
		background-color: #d4d4ce;
		border-radius: 6px;
	}
	.filter-status[hidden] {
		display: none;
	}
	.status-line {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0 0.5em;
		font-size: 0.85em;
	}
	.status-label {
		color: var(--muted);
	}
	.tag-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0 0.5em;
	}
	.chip {
		font-family: inherit;
		font-size: 1.1em;
		font-weight: bold;
		color: var(--text);
		text-decoration: underline;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
	}
	.chip:hover {
		color: var(--accent);
	}
	.reset {
		align-self: flex-start;
		font-size: 0.75em;
		color: var(--muted);
		text-decoration: underline;
		background: none;
		border: none;
		padding: 0;
		font-family: inherit;
		cursor: pointer;
	}
	.reset:hover {
		color: var(--accent);
	}
</style>

<script>
	const indexRoot = document.querySelector('[data-post-index]');
	const yearButtons = document.querySelectorAll<HTMLButtonElement>('.filter-menu button[data-year]');
	const tagLinks = document.querySelectorAll<HTMLAnchorElement>('.filter-menu a[data-tag]');
	const tagMenuEl = document.querySelector<HTMLElement>('.tags-menu');
	const statusEl = document.querySelector<HTMLElement>('.filter-status');
	const yearChip = document.querySelector<HTMLButtonElement>('.chip[data-remove="year"]');
	const tagChipsEl = document.querySelector<HTMLElement>('.tag-chips');
	const resetBtn = document.querySelector<HTMLButtonElement>('.reset');
	const toggleTagsBtn = document.querySelector<HTMLButtonElement>('.toggle-tags');

	if (
		indexRoot &&
		statusEl &&
		yearChip &&
		tagChipsEl &&
		resetBtn &&
		toggleTagsBtn &&
		(yearButtons.length > 0 || tagLinks.length > 0)
	) {
		const TAG_VISIBLE_LINES = 2;
		let tagsExpanded = false;

		const initialParams = new URLSearchParams(location.search);
		let activeYear = initialParams.get('year');
		// Tags AND together — a post must carry every selected tag to match.
		const activeTags = new Set(
			(initialParams.get('tag') || '').split(',').filter(Boolean),
		);

		// Counts posts matching the current year plus every tag in `required`.
		function countMatches(required: string[]) {
			let count = 0;
			indexRoot?.querySelectorAll('li[data-tags][data-year]').forEach((li) => {
				if (activeYear && li.getAttribute('data-year') !== activeYear) return;
				const tags = (li.getAttribute('data-tags') || '').split(',').filter(Boolean);
				if (required.every((tag) => tags.includes(tag))) count++;
			});
			return count;
		}

		// A year change can strand an active tag combo at zero results even
		// though no single tag in it looks invalid on its own (e.g. two tags
		// that co-occur in 2023 but never together in 2022). Rebuild the
		// active set one tag at a time, dropping whichever tag would be the
		// one to zero it out.
		function pruneInvalidActiveTags() {
			const kept: string[] = [];
			for (const tag of activeTags) {
				kept.push(tag);
				if (countMatches(kept) === 0) {
					kept.pop();
					activeTags.delete(tag);
				}
			}
		}

		// Narrows the tag list to only the tags that would still produce at
		// least one result together with the current year and the already
		// selected tags — so picking a second (or third) tag can never lead
		// to a dead end, the same way picking a year already narrows tags.
		// Visibility itself is left to applyTagVisibility, which also folds
		// in the collapsed/expanded state.
		function updateTagAvailability() {
			pruneInvalidActiveTags();

			tagLinks.forEach((link) => {
				const tag = link.getAttribute('data-tag') as string;
				const isActive = activeTags.has(tag);
				const required = isActive ? [...activeTags] : [...activeTags, tag];
				const count = countMatches(required);
				const li = link.closest('li');
				if (li) li.dataset.narrowed = count === 0 && !isActive ? 'true' : 'false';
				const countEl = link.querySelector('.count');
				if (countEl) countEl.textContent = `(${count})`;
			});

			applyTagVisibility();
		}

		// Hides narrowed-out tags, then clips the remaining ones to
		// TAG_VISIBLE_LINES worth of height — measured from an actual
		// rendered row rather than a fixed item count, so the cutoff tracks
		// however many tags happen to fit at the current viewport width.
		function applyTagVisibility() {
			tagLinks.forEach((link) => {
				const li = link.closest('li');
				if (li) (li as HTMLElement).hidden = li.dataset.narrowed === 'true';
			});
			updateTagCollapse();
		}

		function updateTagCollapse() {
			if (!tagMenuEl) return;
			const visibleRows = [...tagLinks]
				.map((link) => link.closest('li') as HTMLElement | null)
				.filter((li): li is HTMLElement => li !== null && !li.hidden);
			if (visibleRows.length === 0) {
				tagMenuEl.style.maxHeight = '';
				toggleTagsBtn.hidden = true;
				toggleTagsBtn.classList.remove('expanded');
				return;
			}
			const rowHeight = visibleRows[0].getBoundingClientRect().height;
			const maxHeight = rowHeight * TAG_VISIBLE_LINES;
			// scrollHeight reflects the full unclipped content regardless of the
			// max-height/overflow below, so it's safe to compare against it here.
			const overflowing = tagMenuEl.scrollHeight > maxHeight + 1;
			toggleTagsBtn.hidden = !overflowing;
			toggleTagsBtn.classList.toggle('expanded', tagsExpanded && overflowing);
			tagMenuEl.style.maxHeight = !overflowing || tagsExpanded ? '' : `${maxHeight}px`;
		}

		function applyFilter() {
			indexRoot?.querySelectorAll('li[data-tags]').forEach((li) => {
				const tags = (li.getAttribute('data-tags') || '').split(',').filter(Boolean);
				const year = li.getAttribute('data-year');
				const matchesYear = !activeYear || year === activeYear;
				const matchesTags = [...activeTags].every((tag) => tags.includes(tag));
				(li as HTMLElement).hidden = !(matchesYear && matchesTags);
			});
			yearButtons.forEach((btn) => {
				btn.classList.toggle('active', btn.getAttribute('data-year') === activeYear);
			});
			tagLinks.forEach((link) => {
				link.classList.toggle('active', activeTags.has(link.getAttribute('data-tag') as string));
			});

			yearChip.hidden = !activeYear;
			if (activeYear) yearChip.textContent = `${activeYear} ×`;

			tagChipsEl.innerHTML = '';
			activeTags.forEach((tag) => {
				// Cloning yearChip (rather than document.createElement) carries
				// over the class Astro's style-scoping compiler injects onto it —
				// a freshly created element wouldn't have that class and would
				// silently fall back to unstyled default button chrome.
				const chip = yearChip.cloneNode(false) as HTMLButtonElement;
				chip.hidden = false;
				chip.removeAttribute('data-remove');
				chip.textContent = `#${tag} ×`;
				chip.addEventListener('click', () => {
					activeTags.delete(tag);
					updateTagAvailability();
					applyFilter();
					updateUrl();
				});
				tagChipsEl.appendChild(chip);
			});

			statusEl.hidden = !activeYear && activeTags.size === 0;
		}

		function updateUrl() {
			const params = new URLSearchParams(location.search);
			if (activeYear) params.set('year', activeYear);
			else params.delete('year');
			if (activeTags.size > 0) params.set('tag', [...activeTags].join(','));
			else params.delete('tag');
			const qs = params.toString();
			history.replaceState(null, '', location.pathname + (qs ? `?${qs}` : ''));
		}

		yearButtons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const year = btn.getAttribute('data-year');
				activeYear = activeYear === year ? null : year;
				updateTagAvailability();
				applyFilter();
				updateUrl();
			});
		});

		tagLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				event.preventDefault();
				const tag = link.getAttribute('data-tag') as string;
				if (activeTags.has(tag)) activeTags.delete(tag);
				else activeTags.add(tag);
				updateTagAvailability();
				applyFilter();
				updateUrl();
			});
		});

		yearChip.addEventListener('click', () => {
			activeYear = null;
			updateTagAvailability();
			applyFilter();
			updateUrl();
		});

		resetBtn.addEventListener('click', () => {
			activeYear = null;
			activeTags.clear();
			updateTagAvailability();
			applyFilter();
			updateUrl();
		});

		toggleTagsBtn.addEventListener('click', () => {
			tagsExpanded = !tagsExpanded;
			updateTagCollapse();
		});

		// Re-measure on resize — how many tags fit in two lines depends on
		// viewport width, so a rotation or window resize can change it.
		let resizeTimer: ReturnType<typeof setTimeout>;
		window.addEventListener('resize', () => {
			clearTimeout(resizeTimer);
			resizeTimer = setTimeout(updateTagCollapse, 150);
		});

		// Always run once to establish the collapsed tag view, independent of
		// whether a filter happens to be active on load.
		updateTagAvailability();
		if (activeYear || activeTags.size > 0) {
			applyFilter();
			updateUrl();
		}

		// Custom webfonts finishing to load after this initial measurement
		// would otherwise reflow the rows to a different height than what got
		// baked into the max-height clip above.
		document.fonts?.ready.then(() => updateTagCollapse());
	}
</script>
